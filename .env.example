# ==============================================
# Environment Variables for WhatsApp AI Assistant
# ==============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ==============================================

# Claude API (if using API key instead of subscription)
ANTHROPIC_API_KEY=sk-ant-api...

# OpenAI (optional fallback)
OPENAI_API_KEY=sk-...

# Google Cloud Project (for Gmail PubSub)
GCP_PROJECT_ID=your-project-id

# Browser automation
CHROMIUM_PATH=/usr/bin/chromium-browser

# Server configuration
PORT=18789
NODE_ENV=production

# Timezone
TZ=Asia/Jakarta

# Logging
LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# Multi-user limits
MAX_USERS=100
MAX_MESSAGES_PER_DAY=500
